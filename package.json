{
  "name": "colab-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "colab": "src/cli/index.ts"
  },
  "scripts": {
    "colab": "bun run src/cli/index.ts",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:snapshot": "bun test test/snapshot",
    "test:diff": "bun test test/differential",
    "test:property": "bun test test/property",
    "typecheck": "tsc --noEmit",
    "test:e2e": "bun run test/e2e/live-validation.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "fast-check": "^4.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
